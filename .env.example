# File .env root 
##########################################
# 💱 CURRENCY
##########################################
DOLLAR_USD_TO_RUPIAH=17000

##########################################
# 🖥️ SERVER CONFIG
##########################################
BIND=0.0.0.0:8080
PORT=8080
RUST_LOG=info
TZ=Asia/Jakarta

##########################################
# 💾 STORAGE & PATHS
##########################################
STORAGE_DIR=/data
HLS_ROOT=/tmp/hls
WATERMARK_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

##########################################
# ☁️  OBJECT STORAGE (default: local disk)
##########################################
# Backend: local (default) | s3 | minio | r2 | b2
STORAGE_BACKEND=local

# --- MinIO (self-hosted, S3-compatible) ---
# STORAGE_BACKEND=minio
# S3_BUCKET=ppv-stream
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_PATH_STYLE=true
# S3_PUBLIC_URL=http://minio:9000/ppv-stream

# --- AWS S3 ---
# STORAGE_BACKEND=s3
# S3_BUCKET=ppv-stream
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=AKIAxxxxxxxxxx
# S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# S3_PUBLIC_URL=https://ppv-stream.s3.ap-southeast-1.amazonaws.com

# --- Cloudflare R2 ---
# STORAGE_BACKEND=r2
# S3_BUCKET=ppv-stream
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=<r2-access-key-id>
# S3_SECRET_KEY=<r2-secret-access-key>
# S3_PATH_STYLE=true
# S3_PUBLIC_URL=https://pub-<hash>.r2.dev   # if R2 public access enabled

##########################################
# 🗄️ DATABASE CONFIG
##########################################
DATABASE_URL=postgres://ppv:secret@db:5432/ppv_stream
DATABASE_URL_BUILD=postgres://ppv:secret@host.docker.internal:5432/ppv_stream

##########################################
# 🔐 SECURITY & HLS SETTINGS
##########################################
HMAC_SECRET=change-this-secret-key-32chars-min
SESSION_TOKEN_TTL=600
HLS_SEGMENT_SECONDS=6

##########################################
# 👩‍💼 BOOTSTRAP ADMIN (opsional)
##########################################
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
ADMIN_BOOTSTRAP_TOKEN=rahasiabanget

##########################################
# 🔗 X402 SMART CONTRACT (Default: Polygon Amoy Testnet)
##########################################
X402_CONTRACT_ADDRESS=0xe375691C0a45db07c9DD7843d12eF283C084AE8A
X402_ADMIN_WALLET=0xB7256FB6fe96b8aDB4B4280E459fBED02C8db6f0
X402_RPC_WSS=wss://polygon-amoy-bor.publicnode.com
X402_CHAIN_ID=80002

# ========== WALLET (WAJIB) ==========
# Private key hex dengan prefix 0x
# !!! JANGAN DI-COMMIT KE GIT !!!
X402_ADMIN_PRIVKEY=

##########################################
# 🚀 DEPLOYER VARS (DIBACA CONTAINER DEPLOYER via env_file)
#    -> Nilai sensitif (PRIVATE_KEY) TIDAK DITARUH DI SINI
##########################################
AMOY_RPC_HTTP=https://polygon-amoy-bor.publicnode.com
AMOY_CHAIN_ID=80002
# (opsional)
# POLYGON_RPC_HTTP=https://polygon-rpc.com
# POLYGON_CHAIN_ID=137
# POLYGONSCAN_API_KEY=your_polygonscan_api_key

