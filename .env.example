# PPV Stream example environment
# Recommended starter profile:
#   PayPal + Xendit + internal wallet

##########################################
# Core application
##########################################

# Non-Docker local example:
DATABASE_URL=postgres://ppv:secret@localhost:5432/ppv_stream

# Docker build example:
DATABASE_URL_BUILD=postgres://ppv:secret@db:5432/ppv_stream

BIND=0.0.0.0:8080
BASE_URL=http://localhost:8080
RUST_LOG=info
TZ=Asia/Jakarta

##########################################
# Security
##########################################

HMAC_SECRET=change-this-to-a-long-random-secret
SESSION_TOKEN_TTL=3600

##########################################
# Storage and paths
##########################################

STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=storage
STORAGE_DIR=storage
UPLOAD_DIR=storage
MEDIA_DIR=media
HLS_ROOT=hls_tmp
TMP_DIR=tmp
PUBLIC_DIR=public
WATERMARK_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf

##########################################
# Upload and media
##########################################

MAX_UPLOAD_BYTES=1073741824
ALLOW_EXTS=mp4,mkv,mov,webm
HLS_SEGMENT_SECONDS=2
HWACCEL=none

##########################################
# Currency and revenue split
##########################################

DOLLAR_USD_TO_RUPIAH=17000
CREATOR_SPLIT_BP=9000

##########################################
# Admin bootstrap
##########################################

ADMIN_BOOTSTRAP_TOKEN=setup-token-123
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!

##########################################
# Payment providers
##########################################

# These control which external plugins are available.
# Internal wallet payment and wallet transfer are now toggled from Admin > Settings.
PAYMENT_PLUGINS=paypal,xendit
PAYMENT_DEFAULT_PROVIDER=paypal

##########################################
# PayPal
##########################################

PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

##########################################
# Xendit
##########################################

XENDIT_ENV=test
XENDIT_SECRET_KEY=your_xendit_secret_key
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token

##########################################
# Stripe (optional)
##########################################

STRIPE_ENV=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

##########################################
# Midtrans (optional)
##########################################

MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

##########################################
# X402 blockchain payment (optional)
##########################################

X402_CONTRACT_ADDRESS=
X402_ADMIN_WALLET=
X402_ADMIN_PRIVKEY=
X402_RPC_HTTP=
X402_RPC_WSS=
X402_CHAIN_ID=80002
X402_DEADLINE_SECS=900
WATCHER_ENABLE=0

##########################################
# Optional S3-compatible storage
##########################################

S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PATH_STYLE=false
S3_PUBLIC_URL=

##########################################
# Optional contract deployer variables
##########################################

PRIVATE_KEY=
AMOY_RPC_HTTP=https://polygon-amoy-bor.publicnode.com
AMOY_CHAIN_ID=80002
POLYGON_RPC_HTTP=https://polygon-rpc.com
POLYGON_CHAIN_ID=137
POLYGONSCAN_API_KEY=
